# Cloudflare Pages headers — https://developers.cloudflare.com/pages/configuration/headers/
#
# CACHING CONTRACT (deploy integrity): HTML pages must never be long-cached.
# Cloudflare Pages serves HTML with `max-age=0, must-revalidate` and
# cf-cache-status: DYNAMIC by default — do not add a Cache-Control for HTML
# routes here, and never add a zone-level "Cache Everything" rule for this
# site. Only fingerprinted/cache-busted assets below get long max-age.
# The post-deploy smoke test (.github/workflows/smoke-test.yml) fails loudly
# if any route serves a stale build.
# SECURITY HEADERS (apply to every route).
#
# HSTS: force HTTPS for a year, incl. subdomains. `preload` is SET here but NOT
# yet submitted — preloading is a one-way commitment (browsers hard-fail HTTP for
# the whole apex + all subdomains). Submit at https://hstspreload.org ONLY after
# confirming every subdomain serves HTTPS. Until submitted, the token is inert.
#
# Content-Security-Policy is now ENFORCED (audited 2026-07: every external
# script/style/font/connect/form target on the site is allowed by the policy;
# see the source map below). The identical Report-Only line stays for ONE more
# release as a canary — if the console ever shows a report-only violation the
# enforced header is blocking the same thing; revert the enforced line to
# Report-Only first, fix, then re-enforce. Drop the Report-Only line next release.
# CSP source map (one policy, served on /*):
#   default-src 'self'        — baseline: same-origin only unless overridden below
#   base-uri 'none'           — no <base> tag is used anywhere; forbid injection of one
#   object-src 'none'         — no <object>/<embed>/<applet>
#   frame-ancestors 'self'    — mirrors X-Frame-Options: SAMEORIGIN
#   frame-src https://calendly.com — the /book/ inline scheduler (the site's
#                               only iframe; direct embed, no widget.js)
#   script-src 'self' 'unsafe-inline' https://plausible.io
#                             — 'self': /js/*.js + Cloudflare /cdn-cgi/ email-decode;
#                               'unsafe-inline': inline init blocks + onclick="window.print()";
#                               plausible.io: analytics loader
#   style-src 'self' 'unsafe-inline' https://fonts.googleapis.com
#                             — 'self': styles.css; 'unsafe-inline': 157 inline style=
#                               attrs + <style> blocks; googleapis: Google Fonts CSS
#   img-src 'self' data:      — 'self': og-image/icons/content; data:: SVG film-grain
#                               in styles.css, inline SVG icons, SVG favicon
#   font-src 'self' https://fonts.gstatic.com — Google Fonts woff2 files
#   connect-src 'self' https://plausible.io https://formspree.io
#                             — 'self': /api/book-assessment + /blog-data/*.json;
#                               plausible.io: event beacons; formspree.io: careers form
#                               (api.resend.com is server-side in the Pages Function, not here)
#   form-action 'self' https://theampersand.beehiiv.com
#                             — 'self': same-origin forms; beehiiv: newsletter subscribe
#   upgrade-insecure-requests — upgrade any stray http subresource (no-op in report-only)
#
# The two CSP lines below MUST stay byte-identical while both ship. To capture
# violations centrally, add a `report-to` directive + a `Report-To` header endpoint.
# Dropping 'unsafe-inline' (nonces or hashes) would require restructuring: the
# pages carry inline <script>/<style> blocks, style= attrs, and onclick handlers
# by design, and static _headers cannot mint per-request nonces (that needs a
# Worker/Function, or build-time hashing of every inline block). Not planned.
# The AI-Ready Score app is reverse-proxied from Vercel at /score/* and /s/*
# (functions/…). It ships standalone with its own scripts, styles, and security
# headers, so detach the main site's CSP + frame rules here — otherwise
# default-src 'self' and the frame rules would block the app.
/score
  ! Content-Security-Policy
  ! Content-Security-Policy-Report-Only
  ! X-Frame-Options
/score/*
  ! Content-Security-Policy
  ! Content-Security-Policy-Report-Only
  ! X-Frame-Options
/s/*
  ! Content-Security-Policy
  ! Content-Security-Policy-Report-Only
  ! X-Frame-Options

/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  Permissions-Policy: geolocation=(), microphone=(), camera=()
  Content-Security-Policy: default-src 'self'; base-uri 'none'; object-src 'none'; frame-ancestors 'self'; frame-src https://calendly.com; script-src 'self' 'unsafe-inline' https://plausible.io; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' data:; font-src 'self' https://fonts.gstatic.com; connect-src 'self' https://plausible.io https://formspree.io; form-action 'self' https://theampersand.beehiiv.com; upgrade-insecure-requests
  Content-Security-Policy-Report-Only: default-src 'self'; base-uri 'none'; object-src 'none'; frame-ancestors 'self'; frame-src https://calendly.com; script-src 'self' 'unsafe-inline' https://plausible.io; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' data:; font-src 'self' https://fonts.gstatic.com; connect-src 'self' https://plausible.io https://formspree.io; form-action 'self' https://theampersand.beehiiv.com; upgrade-insecure-requests

# styles.css is cache-busted via ?v=N in index.html, so it can cache for a while
/styles.css
  Cache-Control: public, max-age=86400

# shared JS is cache-busted via ?v=N in the pages that load it
/js/*
  Cache-Control: public, max-age=86400

# Blog search/teaser data — short cache, refreshed on every deploy
/blog-data/*
  Cache-Control: public, max-age=300
  Content-Type: application/json; charset=utf-8

/blog/rss.xml
  Content-Type: application/rss+xml; charset=utf-8
  Cache-Control: public, max-age=1800

# Force classic favicon MIME (Cloudflare defaults .ico to image/vnd.microsoft.icon)
/favicon.ico
  Content-Type: image/x-icon
  Cache-Control: public, max-age=604800

# llms.txt — plain text for LLM/agent consumption
/llms.txt
  Content-Type: text/plain; charset=utf-8
  Cache-Control: public, max-age=3600

# App icons
/apple-touch-icon.png
  Cache-Control: public, max-age=604800
/icon-512.png
  Cache-Control: public, max-age=604800
