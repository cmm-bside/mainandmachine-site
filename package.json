{
  "name": "mainandmachine-site",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Main & Machine — static site with a build-time blog (The Ampersand) sourced from beehiiv.",
  "scripts": {
    "blog:fetch": "node scripts/fetch-blog-posts.mjs",
    "blog:build": "node scripts/build-blog.mjs",
    "seo:check": "node scripts/check-seo.mjs",
    "seo:dates": "node scripts/build-page-dates.mjs",
    "facts:check": "node scripts/check-facts.mjs",
    "llms:build": "node scripts/build-llms.mjs",
    "work:build": "node scripts/build-work.mjs",
    "placeholders:check": "node scripts/check-placeholders.mjs",
    "book:check": "node scripts/check-book.mjs",
    "smoke:test": "node scripts/smoke-test.mjs",
    "sweep:mobile": "node scripts/mobile-sweep.mjs",
    "test:book": "node scripts/test-book-assessment.mjs",
    "build:static": "npm run blog:fetch && npm run blog:build && npm run llms:build && npm run work:build && npm run seo:check && npm run facts:check && npm run placeholders:check && npm run book:check",
    "postinstall": "node scripts/build-blog.mjs",
    "preview": "python3 -m http.server 8000"
  },
  "dependencies": {
    "image-size": "^1.2.1",
    "sanitize-html": "^2.13.0"
  }
}
